# 摇摆舞分析器环境变量配置

# ==================== LLM 建议配置 ====================

# 是否启用大模型生成建议（true/false）
USE_LLM_SUGGESTIONS=true

# 选择 LLM 提供商：claude / openai / dashscope
LLM_PROVIDER=claude

# -------------------- Claude 配置 --------------------
# 获取 API Key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxx
CLAUDE_MODEL=claude-3-5-sonnet-20241022
# 可选模型：
# - claude-3-5-sonnet-20241022 (推荐，平衡性价比)
# - claude-3-opus-20240229 (最贵，质量最好)
# - claude-3-haiku-20240307 (最便宜，速度快)

# -------------------- OpenAI 配置 --------------------
# 获取 API Key: https://platform.openai.com/
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o-mini
# 可选模型：
# - gpt-4o-mini (推荐，性价比最高)
# - gpt-4o (质量最好，较贵)
# - gpt-3.5-turbo (便宜但质量一般)

# -------------------- 通义千问配置 --------------------
# 获取 API Key: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxx
DASHSCOPE_MODEL=qwen-turbo
# 可选模型：
# - qwen-turbo (最便宜)
# - qwen-plus (平衡)
# - qwen-max (质量最好)
